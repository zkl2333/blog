---
import { type CollectionEntry, render } from "astro:content";

import Breadcrumb from "@/components/Breadcrumb.astro";
import Masthead from "@/components/blog/Masthead.astro";
import TOC from "@/components/blog/TOC.astro";
import Comments from "@/components/Comments.astro";
import WebMentions from "@/components/blog/webmentions/index.astro";

import BaseLayout from "./Base.astro";

interface Props {
	post: CollectionEntry<"post">;
}

const { post } = Astro.props;
const { ogImage, title, description, updatedDate, publishDate } = post.data;
const socialImage = ogImage ?? `/og-image/${post.id}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();
const { headings, remarkPluginFrontmatter } = await render(post);
const readingTime: string = remarkPluginFrontmatter.readingTime;
---

<BaseLayout
	meta={{
		articleDate,
		description,
		ogImage: socialImage,
		title,
	}}
>
	<Breadcrumb
		items={[{ label: "首页", href: "/" }, { label: "文章", href: "/posts/" }, { label: title }]}
	/>
	<article class="grow wrap-break-word" data-pagefind-body>
		<div id="blog-hero" class="mb-10"><Masthead content={post} readingTime={readingTime} /></div>
		{post.data.toc !== false && !!headings.length && <TOC headings={headings} />}
		<div
			class:list={[
				"prose prose-headings:font-semibold prose-h2:font-bold prose-headings:text-accent-2 sm:prose-th:before:content-none !max-w-none min-w-0 lg:max-w-[52rem] xl:max-w-[56rem]",
			]}
		>
			<slot />
			<WebMentions />
		</div>
		<Comments />
	</article>
	<button
		class="hover:border-link fixed inset-e-4 bottom-8 z-90 flex h-10 w-10 translate-y-28 cursor-pointer items-center justify-center rounded-full border-2 border-transparent bg-zinc-200 text-3xl opacity-0 transition-all transition-discrete duration-300 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 sm:inset-e-8 sm:h-12 sm:w-12 dark:bg-zinc-700"
		data-show="false"
		id="to-top-btn"
	>
		<span class="sr-only">回到顶部</span>
		<svg
			aria-hidden="true"
			class="h-6 w-6"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>
</BaseLayout>

<script>
	// 特稿/海报组件：滚动渐入（仅含这些组件的文章生效；无 JS 时照常显示）
	function initPosterReveal() {
		const sel = ".pf-lead, .pf-act, .pf-quote, .pf-aside, .pf-vs, .pf-stats, .pf-steps, .pf-cards";
		const targets = document.querySelectorAll(`.prose :is(${sel})`);
		if (!targets.length) return;
		if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
		const io = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						entry.target.classList.add("is-in");
						io.unobserve(entry.target);
					}
				}
			},
			{ threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
		);
		for (const el of targets) {
			if (el.classList.contains("pf-reveal")) continue;
			el.classList.add("pf-reveal");
			io.observe(el);
		}
	}
	initPosterReveal();
	document.addEventListener("astro:page-load", initPosterReveal);
</script>

<script>
	const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement;
	const targetHeader = document.getElementById("blog-hero") as HTMLDivElement;

	function callback(entries: IntersectionObserverEntry[]) {
		entries.forEach((entry) => {
			// only show the scroll to top button when the heading is out of view
			scrollBtn.dataset.show = (!entry.isIntersecting).toString();
		});
	}

	scrollBtn.addEventListener("click", () => {
		document.documentElement.scrollTo({ behavior: "smooth", top: 0 });
	});

	const observer = new IntersectionObserver(callback);
	observer.observe(targetHeader);
</script>

<script>
	import mermaid, { type MermaidConfig } from "mermaid";

	let mermaidTheme: string | null = null;

	/** 根据当前 data-theme 返回暖色系 Mermaid 配置 */
	function getMermaidConfig(): MermaidConfig {
		const isDark = document.documentElement.dataset.theme === "dark";
		return {
			startOnLoad: false,
			securityLevel: "loose",
			theme: "base",
			flowchart: { useMaxWidth: false, htmlLabels: true },
			sequence: { useMaxWidth: false },
			themeVariables: isDark
				? {
						// —— 基础色 ——
						background: "transparent",
						mainBkg: "#38241a",
						primaryColor: "#38241a",
						secondaryColor: "#2e1c12",
						tertiaryColor: "#3c2850",
						primaryBorderColor: "#5a3c2a",
						primaryTextColor: "#e8d4b8",
						nodeBorder: "#5a3c2a",
						lineColor: "#a08068",
						textColor: "#e8d4b8",
						edgeLabelBackground: "#2e1c12",
						// —— 深夜食堂色板：8色循环，subgraph 自动取色 ——
						cScale0: "#38241a", // 深棕 · 底色
						cScale1: "#5c3818", // 琥珀棕
						cScale2: "#5a3010", // 焦糖
						cScale3: "#3c2850", // 深紫
						cScale4: "#1e3c28", // 深林绿
						cScale5: "#1a2e4a", // 深海蓝
						cScale6: "#4a1e30", // 深玫红
						cScale7: "#2c3c10", // 橄榄
						cScalePeer0: "#5a3c2a",
						cScalePeer1: "#8a5828",
						cScalePeer2: "#8a5020",
						cScalePeer3: "#6a4880",
						cScalePeer4: "#3a6048",
						cScalePeer5: "#2a4870",
						cScalePeer6: "#783050",
						cScalePeer7: "#486020",
					}
				: {
						// —— 基础色 ——
						background: "transparent",
						mainBkg: "#faf4e8",
						primaryColor: "#faf4e8",
						secondaryColor: "#f0e8d4",
						tertiaryColor: "#cdb8e0",
						primaryBorderColor: "#c4a882",
						primaryTextColor: "#3a2218",
						nodeBorder: "#c4a882",
						lineColor: "#9a7860",
						textColor: "#3a2218",
						edgeLabelBackground: "#faf4e8",
						// —— 食材色板：8色循环，subgraph 自动取色 ——
						cScale0: "#faf4e8", // 奶油白 · 底色
						cScale1: "#f5d98c", // 蜂蜜金
						cScale2: "#f0a870", // 橘橙
						cScale3: "#cdb8e0", // 薰衣紫
						cScale4: "#a8c89c", // 抹茶绿
						cScale5: "#96bdd8", // 青瓷蓝
						cScale6: "#f0a0a8", // 樱花粉
						cScale7: "#c4d870", // 嫩豆绿
						cScalePeer0: "#c4a882",
						cScalePeer1: "#c49840",
						cScalePeer2: "#c07840",
						cScalePeer3: "#9878c0",
						cScalePeer4: "#709868",
						cScalePeer5: "#5888a8",
						cScalePeer6: "#c07080",
						cScalePeer7: "#90a840",
					},
		};
	}

	async function renderMermaid() {
		const diagrams = Array.from(document.querySelectorAll<HTMLPreElement>("pre.mermaid")).filter(
			(node) => !node.dataset.mermaidRendered,
		);

		if (!diagrams.length) return;

		const currentTheme = document.documentElement.dataset.theme ?? "light";
		if (mermaidTheme !== currentTheme) {
			mermaid.initialize(getMermaidConfig());
			mermaidTheme = currentTheme;
		}

		for (const diagram of diagrams) {
			diagram.dataset.mermaidSource = (diagram.textContent ?? "").trim();
			diagram.dataset.mermaidRendered = "true";
		}

		await mermaid.run({ nodes: diagrams });

		// 渲染后：保留 Mermaid 自算的像素宽度（不强制 100%），仅防溢出 + 居中
		for (const diagram of diagrams) {
			const svg = diagram.querySelector("svg");
			if (svg) {
				svg.style.display = "block";
				svg.style.maxWidth = "100%";
				svg.style.height = "auto";
				svg.style.marginInline = "auto";
			}
		}
	}

	/** 主题切换时重新渲染已有图表 */
	async function reRenderMermaid() {
		const diagrams = Array.from(
			document.querySelectorAll<HTMLPreElement>("pre.mermaid[data-mermaid-rendered]"),
		);
		if (!diagrams.length) return;
		for (const diagram of diagrams) {
			const source = diagram.dataset.mermaidSource ?? "";
			diagram.innerHTML = "";
			diagram.textContent = source;
			diagram.removeAttribute("data-mermaid-rendered");
			// 清除 Mermaid 内部的"已处理"标记，否则 mermaid.run() 会跳过该元素
			diagram.removeAttribute("data-processed");
		}
		mermaidTheme = null;
		await renderMermaid();
	}

	renderMermaid();
	document.addEventListener("astro:page-load", renderMermaid);

	// 监听 data-theme 变化，重新渲染图表配色
	const themeObserver = new MutationObserver(reRenderMermaid);
	themeObserver.observe(document.documentElement, {
		attributes: true,
		attributeFilter: ["data-theme"],
	});
</script>
