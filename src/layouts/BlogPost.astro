---
import { type CollectionEntry, render } from "astro:content";

import Masthead from "@/components/blog/Masthead.astro";
import TOC from "@/components/blog/TOC.astro";
import WebMentions from "@/components/blog/webmentions/index.astro";

import BaseLayout from "./Base.astro";

interface Props {
	post: CollectionEntry<"post">;
}

const { post } = Astro.props;
const { ogImage, title, description, updatedDate, publishDate } = post.data;
const socialImage = ogImage ?? `/og-image/${post.id}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();
const { headings, remarkPluginFrontmatter } = await render(post);
const readingTime: string = remarkPluginFrontmatter.readingTime;
---

<BaseLayout
	bodyClass="lg:max-w-6xl"
	meta={{
		articleDate,
		description,
		ogImage: socialImage,
		title,
	}}
>
	<article class="grow wrap-break-word" data-pagefind-body>
		<div id="blog-hero" class="mb-12"><Masthead content={post} readingTime={readingTime} /></div>
		<div class="flex min-w-0 flex-col gap-10 lg:flex-row lg:items-start lg:justify-between lg:gap-12">
			{!!headings.length && <TOC headings={headings} />}
			<div
				class="prose min-w-0 !max-w-none prose-headings:font-semibold prose-h2:font-bold prose-headings:text-accent-2 prose-headings:before:absolute prose-headings:before:-ms-4 prose-headings:before:text-muted prose-headings:hover:before:text-accent sm:prose-headings:before:content-['#'] sm:prose-th:before:content-none lg:max-w-[52rem] xl:max-w-[56rem]"
			>
				<slot />
				<WebMentions />
			</div>
		</div>
	</article>
	<button
		class="hover:border-link fixed inset-e-4 bottom-8 z-90 flex h-10 w-10 translate-y-28 cursor-pointer items-center justify-center rounded-full border-2 border-transparent bg-zinc-200 text-3xl opacity-0 transition-all transition-discrete duration-300 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 sm:inset-e-8 sm:h-12 sm:w-12 dark:bg-zinc-700"
		data-show="false"
		id="to-top-btn"
	>
		<span class="sr-only">回到顶部</span>
		<svg
			aria-hidden="true"
			class="h-6 w-6"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>
</BaseLayout>

<script>
	const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement;
	const targetHeader = document.getElementById("blog-hero") as HTMLDivElement;

	function callback(entries: IntersectionObserverEntry[]) {
		entries.forEach((entry) => {
			// only show the scroll to top button when the heading is out of view
			scrollBtn.dataset.show = (!entry.isIntersecting).toString();
		});
	}

	scrollBtn.addEventListener("click", () => {
		document.documentElement.scrollTo({ behavior: "smooth", top: 0 });
	});

	const observer = new IntersectionObserver(callback);
	observer.observe(targetHeader);
</script>

<script>
	import Panzoom from "@panzoom/panzoom";
	import mermaid from "mermaid";

	let mermaidInitialized = false;
	const viewerInstances = new WeakMap();

	const MERMAID_KEYWORDS =
		/\b(flowchart|graph|sequenceDiagram|classDiagram|stateDiagram(?:-v2)?|erDiagram|gantt|pie|journey|mindmap|timeline|gitGraph|requirementDiagram|quadrantChart|xychart-beta|sankey-beta|subgraph|end|direction|click|class|classDef|style|linkStyle|note|loop|alt|opt|par|rect|activate|deactivate|participant|actor|as|TB|TD|BT|RL|LR)\b/g;

	function escapeHtml(value: string) {
		return value.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
	}

	function highlightMermaid(source: string) {
		const lines = source.split("\n");
		return lines
			.map((line) => {
				const commentMatch = line.match(/^(\s*)(%%.*)$/);
				if (commentMatch) {
					return `${commentMatch[1]}<span class="mm-comment">${escapeHtml(commentMatch[2]!)}</span>`;
				}
				let html = escapeHtml(line);
				html = html.replace(
					/(&quot;[^&]*?&quot;|&#39;[^&]*?&#39;|"[^"]*"|'[^']*')/g,
					'<span class="mm-string">$1</span>',
				);
				html = html.replace(
					/(--&gt;|--[xo]|==&gt;|-\.-&gt;|-\.-|---|--|&lt;--&gt;|&lt;--|::|:::)/g,
					'<span class="mm-arrow">$1</span>',
				);
				html = html.replace(
					/(\[\[?|\]\]?|\{\{?|\}\}?|\(\(?|\)\)?|&gt;|&lt;)/g,
					'<span class="mm-bracket">$1</span>',
				);
				html = html.replace(MERMAID_KEYWORDS, '<span class="mm-keyword">$1</span>');
				return html;
			})
			.join("\n");
	}

	const toolbarIcons = {
		code: `<svg aria-hidden="true" viewBox="0 0 20 20"><path d="m7.4 6.6-3 3.4 3 3.4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6"></path><path d="m12.6 6.6 3 3.4-3 3.4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6"></path><path d="m11.1 5.2-2.2 9.6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.5"></path></svg>`,
		preview: `<svg aria-hidden="true" viewBox="0 0 20 20"><path d="M7.2 5.3v9.4c0 .8.9 1.3 1.6.9l7-4.7c.6-.4.6-1.4 0-1.8l-7-4.7c-.7-.5-1.6 0-1.6.9Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="1.5"></path></svg>`,
		zoomIn: `<svg aria-hidden="true" viewBox="0 0 20 20"><path d="M10 4v12M4 10h12" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.7"></path></svg>`,
		zoomOut: `<svg aria-hidden="true" viewBox="0 0 20 20"><path d="M4 10h12" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.7"></path></svg>`,
	};

	const TOOLBAR_BUTTON_CLASS =
		"mermaid-btn relative z-10 inline-flex h-8 w-8 items-center justify-center rounded-full border border-transparent text-[#e6e6e6] hover:bg-white/10 hover:border-white/15 focus-visible:bg-white/10 focus-visible:border-white/15 outline-none cursor-pointer transition-colors";

	function createToolbarButton(icon: string, action: string, title: string) {
		const button = document.createElement("button");
		button.type = "button";
		button.className = TOOLBAR_BUTTON_CLASS;
		button.dataset.action = action;
		button.ariaLabel = title;
		button.title = title;
		button.innerHTML = icon;
		const svg = button.querySelector("svg");
		if (svg) svg.classList.add("h-[1.05rem]", "w-[1.05rem]");
		return button;
	}

	function createFloatingButton(icon: string, action: string, title: string) {
		const button = createToolbarButton(icon, action, title);
		button.className = `${TOOLBAR_BUTTON_CLASS} h-9 w-9 rounded-none border-0 hover:bg-white/[0.08] [&+&]:border-t [&+&]:border-white/10`;
		return button;
	}

	function createViewerLabel() {
		const label = document.createElement("div");
		label.className =
			"inline-flex items-center gap-2 text-sm font-bold leading-none text-[#e6e6e6]";
		label.innerHTML = `<span aria-hidden="true" class="font-mono text-xs tracking-tighter text-[#9aa0a6]">&lt;/&gt;</span><span>Mermaid</span>`;
		return label;
	}

	function ensureViewer(diagram: HTMLElement) {
		const currentViewer = diagram.closest<HTMLElement>(".mermaid-viewer");
		if (currentViewer) {
			return currentViewer;
		}

		const viewer = document.createElement("figure");
		viewer.className =
			"mermaid-viewer not-prose my-7 overflow-hidden rounded-2xl border border-white/[0.06] bg-[#1c1d1d] p-2.5 shadow-[0_16px_34px_-26px_rgba(0,0,0,0.7)]";

		const toolbar = document.createElement("figcaption");
		toolbar.className = "flex items-center justify-between gap-4 pb-2";

		const controls = document.createElement("div");
		controls.className =
			"mermaid-controls relative flex flex-none items-center gap-0.5 rounded-full bg-white/[0.08] p-0.5";
		controls.ariaLabel = "切换视图";

		const indicator = document.createElement("div");
		indicator.className =
			"mermaid-indicator pointer-events-none absolute left-0.5 top-0.5 h-8 w-8 rounded-full bg-[#1c1d1d] shadow-[0_1px_6px_-4px_rgba(0,0,0,0.6)] transition-transform duration-200";
		indicator.ariaHidden = "true";
		controls.append(indicator);

		const codeButton = createToolbarButton(toolbarIcons.code, "code", "查看源码");
		const previewButton = createToolbarButton(toolbarIcons.preview, "preview", "预览图表");
		controls.append(codeButton, previewButton);
		controls.dataset.active = "preview";
		indicator.style.transform = "translateX(calc(100% + 0.125rem))";
		toolbar.append(createViewerLabel(), controls);

		const viewport = document.createElement("div");
		viewport.className =
			"mermaid-viewport relative flex items-center justify-center overflow-hidden rounded-xl border border-white/5 bg-[#131414] cursor-grab touch-none active:cursor-grabbing";
		viewport.style.minHeight = "20rem";
		viewport.style.maxHeight = "min(78vh, 48rem)";

		const zoomControls = document.createElement("div");
		zoomControls.className =
			"mermaid-zoom pointer-events-none absolute bottom-3 right-3 z-10 flex flex-col overflow-hidden rounded-full border border-white/10 bg-[#26282b] opacity-0 shadow-[0_12px_28px_-18px_rgba(0,0,0,0.8)] transition-opacity duration-150";

		zoomControls.append(
			createFloatingButton(toolbarIcons.zoomIn, "zoom-in", "放大图表"),
			createFloatingButton(toolbarIcons.zoomOut, "zoom-out", "缩小图表"),
		);

		const codeView = document.createElement("pre");
		codeView.className =
			"mermaid-code m-0 overflow-auto whitespace-pre rounded-xl bg-transparent px-4 py-3 font-mono text-sm leading-relaxed text-[#e6e6e6]";
		codeView.hidden = true;

		diagram.before(viewer);
		viewport.append(diagram);
		viewport.append(zoomControls);
		viewer.append(toolbar, viewport, codeView);

		return viewer;
	}

	function fitDiagram(svg: SVGSVGElement, panzoom: any, viewport: HTMLElement) {
		panzoom.reset({ animate: false });
		const viewportRect = viewport.getBoundingClientRect();
		const svgRect = svg.getBoundingClientRect();

		if (!viewportRect.width || !svgRect.width || !svgRect.height) {
			return;
		}

		const padding = 24;
		const scaleX = (viewportRect.width - padding) / svgRect.width;
		const scaleY = (viewportRect.height - padding) / svgRect.height;
		const scale = Math.min(Math.max(Math.min(scaleX, scaleY), 0.4), 3);
		panzoom.zoom(scale, { animate: true });
		panzoom.pan(0, 0, { animate: true });
	}

	function enablePanzoom(diagram: HTMLElement) {
		const svg = diagram.querySelector("svg");
		if (!svg || viewerInstances.has(svg)) {
			return;
		}

		svg.removeAttribute("style");
		svg.style.maxWidth = "100%";
		svg.style.height = "auto";

		const viewer = ensureViewer(diagram);
		const viewport = viewer.querySelector<HTMLDivElement>(".mermaid-viewport");
		if (!viewport) {
			return;
		}

		const panzoom = Panzoom(svg, {
			maxScale: 6,
			minScale: 0.2,
			startScale: 1,
		});

		viewerInstances.set(svg, panzoom);
		viewport.addEventListener("wheel", panzoom.zoomWithWheel, { passive: false });
		viewport.addEventListener("dblclick", () => {
			panzoom.zoomIn({ animate: true });
		});

		viewport.addEventListener("mouseenter", () => {
			const zoom = viewer.querySelector<HTMLDivElement>(".mermaid-zoom");
			if (zoom) {
				zoom.style.opacity = "1";
				zoom.style.pointerEvents = "auto";
			}
		});
		viewport.addEventListener("mouseleave", () => {
			const zoom = viewer.querySelector<HTMLDivElement>(".mermaid-zoom");
			if (zoom) {
				zoom.style.opacity = "0";
				zoom.style.pointerEvents = "none";
			}
		});

		const controls = viewer.querySelector<HTMLDivElement>(".mermaid-controls");
		const indicator = viewer.querySelector<HTMLDivElement>(".mermaid-indicator");
		const codeView = viewer.querySelector<HTMLPreElement>(".mermaid-code");
		const source = diagram.dataset.mermaidSource ?? "";
		if (codeView) {
			codeView.innerHTML = highlightMermaid(source);
		}

		function setMode(mode: "preview" | "code") {
			if (!controls) return;
			controls.dataset.active = mode;
			if (indicator) {
				indicator.style.transform =
					mode === "preview" ? "translateX(calc(100% + 0.125rem))" : "translateX(0)";
			}
			if (mode === "code") {
				viewport!.hidden = true;
				if (codeView) codeView.hidden = false;
			} else {
				viewport!.hidden = false;
				if (codeView) codeView.hidden = true;
			}
		}

		viewer.addEventListener("click", (event) => {
			const button = event.target instanceof Element ? event.target.closest(".mermaid-btn") : null;
			if (!button) {
				return;
			}

			const action = (button as HTMLButtonElement).dataset.action;
			if (action === "zoom-in") {
				panzoom.zoomIn({ animate: true });
			} else if (action === "zoom-out") {
				panzoom.zoomOut({ animate: true });
			} else if (action === "reset") {
				panzoom.reset({ animate: true });
			} else if (action === "code") {
				setMode("code");
			} else if (action === "preview") {
				setMode("preview");
			}
		});

		requestAnimationFrame(() => fitDiagram(svg as SVGSVGElement, panzoom, viewport!));
	}

	async function renderMermaid() {
		const diagrams = Array.from(document.querySelectorAll<HTMLPreElement>("pre.mermaid")).filter(
			(node) => !node.dataset.mermaidRendered,
		);

		if (!diagrams.length) {
			return;
		}

		if (!mermaidInitialized) {
			mermaid.initialize({
				startOnLoad: false,
				securityLevel: "loose",
				theme: "dark",
				flowchart: { useMaxWidth: false, htmlLabels: true },
				sequence: { useMaxWidth: false },
				themeVariables: {
					background: "transparent",
					mainBkg: "#1c1d1d",
					primaryColor: "#1c1d1d",
					secondaryColor: "#1c1d1d",
					tertiaryColor: "#1c1d1d",
					primaryBorderColor: "#d0d0d0",
					primaryTextColor: "#e6e6e6",
					nodeBorder: "#d0d0d0",
					lineColor: "#9aa0a6",
					textColor: "#e6e6e6",
					edgeLabelBackground: "#131414",
					clusterBkg: "transparent",
					clusterBorder: "#9aa0a6",
				},
			});
			mermaidInitialized = true;
		}

		for (const diagram of diagrams) {
			diagram.dataset.mermaidSource = (diagram.textContent ?? "").trim();
			diagram.dataset.mermaidRendered = "true";
		}

		await mermaid.run({ nodes: diagrams });

		for (const diagram of diagrams) {
			enablePanzoom(diagram);
		}
	}

	renderMermaid();
	document.addEventListener("astro:page-load", renderMermaid);
</script>
