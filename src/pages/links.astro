---
import Breadcrumb from "@/components/Breadcrumb.astro";
import PageLayout from "@/layouts/Base.astro";

const candidateLinks = [
	{ domain: "diygod.cc", label: "Hi, DIYgod" },
	{ domain: "jasonchao.me", label: "八万光年" },
	{ domain: "ibadboy.net", label: "坏蛋的博客" },
	{ domain: "linmi.cc", label: "Linmi" },
	{ domain: "blog.ikyxxs.com", label: "飨宴" },
	{ domain: "imhan.com", label: "Hanny's Blog" },
	{ domain: "blog.xgblack.cn", label: "臾离博客" },
	{ domain: "isenchun.cn", label: "森纯博客" },
	{ domain: "dreamwings.cn", label: "Dreamwings" },
	{ domain: "zrj96.com", label: "初行博客" },
];

const initial = (label: string) => {
	const trimmed = label.replace(/^Hi[,，]?\s*/i, "").trim();
	return trimmed[0] ?? label[0] ?? "·";
};

const meta = {
	description: "多吃点的小饭桌 — 友链列表",
	title: "友链",
};
---

<PageLayout meta={meta}>
	<Breadcrumb items={[{ label: "首页", href: "/" }, { label: "友链" }]} />

	<header class="page-head">
		<span class="section-head__dot" aria-hidden="true"></span>
		<h1 class="page-head__title">友链 <span class="hero-board__emoji">🍻</span></h1>
	</header>
	<p class="page-head__desc">
		曾经交换过友链的小伙伴，来自 2019 年 Typecho 时代的回忆 ✨ 从 Wayback Machine 快照和 diygod.cc
		友邻列表中找回，已验证存活。
	</p>

	<ul class="link-grid" role="list">
		{
			candidateLinks.map((link, i) => (
				<li>
					<a
						class="link-card"
						href={`https://${link.domain}/`}
						rel="noreferrer noopener"
						target="_blank"
					>
						<span class={`link-card__avatar link-card__avatar--c${i % 5}`} aria-hidden="true">
							{initial(link.label)}
						</span>
						<span class="link-card__body">
							<span class="link-card__label">{link.label}</span>
							<span class="link-card__domain">{link.domain}</span>
						</span>
					</a>
				</li>
			))
		}
	</ul>
</PageLayout>
