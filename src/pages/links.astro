---
import PageLayout from "@/layouts/Base.astro";

const candidateLinks = [
	{ domain: "diygod.cc", label: "Hi, DIYgod" },
	{ domain: "jasonchao.me", label: "八万光年" },
	{ domain: "ibadboy.net", label: "坏蛋的博客" },
	{ domain: "linmi.cc", label: "Linmi" },
	{ domain: "blog.ikyxxs.com", label: "飨宴" },
	{ domain: "imhan.com", label: "Hanny's Blog" },
	{ domain: "blog.xgblack.cn", label: "臾离博客" },
	{ domain: "isenchun.cn", label: "森纯博客" },
	{ domain: "dreamwings.cn", label: "Dreamwings" },
	{ domain: "zrj96.com", label: "初行博客" },
];

const meta = {
	description: "多吃点的小饭桌 — 友链列表",
	title: "友链",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-6">友链</h1>
	<p class="text-muted mb-8 max-w-2xl">
		曾经交换过友链的小伙伴们，来自 2019 年 Typecho 时代的回忆 ✨<br />
		从 Wayback Machine 快照和 diygod.cc 友邻列表中找回，已验证存活。
	</p>

	<section aria-labelledby="links-title">
		<h2 id="links-title" class="title mb-4 text-xl">友链</h2>
		<ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3" role="list">
			{
				candidateLinks.map((link) => (
					<li>
						<a
							class="border-muted/30 bg-global-text/5 hover:border-link hover:bg-global-text/8 block rounded-md border px-4 py-3 transition-colors"
							href={`https://${link.domain}/`}
							rel="noreferrer noopener"
							target="_blank"
						>
							<span class="block text-base font-semibold">{link.label}</span>
							<span class="text-muted block text-sm">{link.domain}</span>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</PageLayout>
