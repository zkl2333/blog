---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "糟糕！这道菜好像撤桌了。",
	title: "404 · 这道菜不在了",
};
---

<PageLayout meta={meta}>
	<section class="not-found">
		<span class="sparkle sparkle--404-1" aria-hidden="true">✦</span>
		<span class="sparkle sparkle--404-2" aria-hidden="true">✦</span>
		<img
			alt=""
			aria-hidden="true"
			class="not-found__deco"
			height={220}
			loading="eager"
			src="/illustrations/bowl.png"
			width={320}
		/>
		<p class="not-found__code">404</p>
		<h1 class="not-found__title">这道菜不在了 🥲</h1>
		<p class="not-found__desc">
			可能是搬桌了、可能是撤了、也可能是当初就没端上来。<br />
			要不回首页坐坐，看看今天还有啥能吃的？
		</p>
		<div class="not-found__cta">
			<a class="btn btn--primary" href="/">回首页</a>
			<a class="btn btn--ghost" href="/posts/">翻翻文章</a>
		</div>
	</section>
</PageLayout>
