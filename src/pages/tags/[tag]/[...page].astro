---
import { render } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import Pagination from "@/components/Paginator.astro";
import { getAllPosts, getTagMeta, getUniqueTags } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

export const getStaticPaths = (async ({ paginate }) => {
	const allPosts = await getAllPosts();
	const sortedPosts = allPosts.sort(collectionDateSort);
	const uniqueTags = getUniqueTags(sortedPosts);

	return uniqueTags.flatMap((tag) => {
		const postsWithTag = sortedPosts.filter((post) => post.data.tags.includes(tag));
		return paginate(postsWithTag, {
			pageSize: 10,
			params: { tag },
		});
	});
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props as Props;
const { tag } = Astro.params;
const tagMeta = await getTagMeta(tag);

const TagContent = tagMeta ? (await render(tagMeta)).Content : null;

const meta = {
	description: tagMeta?.data.description ?? `查看带有标签 ${tag} 的所有文章`,
	title: tagMeta?.data.title ?? `关于 ${tag} 的文章`,
};

const paginationProps = {
	...(page.url.prev && {
		prevUrl: {
			text: "← 上一组标签",
			url: page.url.prev,
		},
	}),
	...(page.url.next && {
		nextUrl: {
			text: "下一组标签 →",
			url: page.url.next,
		},
	}),
};
---

<PageLayout meta={meta}>
	<Breadcrumb
		items={[
			{ label: "首页", href: "/" },
			{ label: "标签", href: "/tags/" },
			{ label: `#${tag}` },
		]}
	/>

	<header class="page-head">
		<span class="section-head__dot" aria-hidden="true"></span>
		<h1 class="page-head__title">
			{tagMeta?.data.title ?? (
				<>
					<span class="post-meta-line__hash" aria-hidden="true">#</span>{tag}
				</>
			)}
		</h1>
	</header>

	{
		(tagMeta?.data.description || TagContent) && (
			<div class="prose prose-cactus !max-w-none mb-10">
				{tagMeta?.data.description && <p>{tagMeta.data.description}</p>}
				{TagContent && <TagContent />}
			</div>
		)
	}

	<ul class="dish-grid" role="list">
		{
			page.data.map((p) => (
				<li>
					<PostPreview as="h2" post={p} withDesc />
				</li>
			))
		}
	</ul>
	<Pagination {...paginationProps} />
</PageLayout>
