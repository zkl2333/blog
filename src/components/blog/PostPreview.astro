---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import type { HTMLTag, Polymorphic } from "astro/types";
import FormattedDate from "@/components/FormattedDate.astro";
import { getEffectiveCover } from "@/data/post";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
	post: CollectionEntry<"post">;
	withDesc?: boolean;
	vertical?: boolean;
};

const { as: Tag = "h3", post, withDesc = false, vertical = false } = Astro.props;
const cover = getEffectiveCover(post);
const tags = post.data.tags?.slice(0, 5) ?? [];
const coverW = vertical ? 480 : 240;
const coverH = vertical ? 270 : 160;
const cls = [
	"dish-card",
	cover && !vertical ? "dish-card--has-cover" : "",
	vertical ? "dish-card--vertical" : "",
].filter(Boolean).join(" ");
---

<article class={cls}>
	{
		cover && (
			<a class="dish-card__cover" href={`/posts/${post.id}/`} tabindex="-1" aria-hidden="true">
				{cover.kind === "local" ? (
					<Image alt={cover.alt} src={cover.src} width={coverW} height={coverH} />
				) : (
					<img alt={cover.alt} src={cover.src} width={coverW} height={coverH} loading="lazy" decoding="async" />
				)}
			</a>
		)
	}
	<div class="dish-card__body">
		<div class="dish-card__meta">
			<FormattedDate class="dish-card__date" date={post.data.publishDate} />
			{post.data.draft && <span class="dish-card__tag dish-card__tag--draft">draft</span>}
			{post.data.pinned && <span class="dish-card__tag dish-card__tag--pin">★ pin</span>}
		</div>
		<Tag class="dish-card__title">
			<a class="dish-card__link" href={`/posts/${post.id}/`}>{post.data.title}</a>
		</Tag>
		{withDesc && post.data.description && <p class="dish-card__desc">{post.data.description}</p>}
		{
			tags.length > 0 && (
				<ul class="dish-card__tags" role="list">
					{tags.map((t: string) => (
						<li>
							<a class="dish-card__chip" href={`/tags/${t}/`}>
								<span aria-hidden="true">#</span>
								{t}
							</a>
						</li>
					))}
				</ul>
			)
		}
	</div>
</article>
