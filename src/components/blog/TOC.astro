---
import type { MarkdownHeading } from "astro";
import { generateToc } from "@/utils/generateToc";
import TOCHeading from "./TOCHeading.astro";

interface Props {
	headings: MarkdownHeading[];
}

const { headings } = Astro.props;

const toc = generateToc(headings);
---

<details class="post-toc">
	<summary class="post-toc__summary">
		<span class="post-toc__label">目录</span>
		<span class="post-toc__hint post-toc__hint--closed">展开</span>
		<span class="post-toc__hint post-toc__hint--open">收起</span>
	</summary>
	<nav class="post-toc__nav" aria-label="文章目录">
		<ol class="post-toc__list">
			{toc.map((heading) => <TOCHeading heading={heading} />)}
		</ol>
	</nav>
</details>
