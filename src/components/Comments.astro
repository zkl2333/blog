---
// Waline 评论区。后端部署在独立子域名 comment.zkl2333.com。
// path 用 location.pathname，与导入数据的 url 字段（/posts/{cid}/、/notes/{cid}/ 等）对应。
---

<div id="waline" class="mt-12" data-pagefind-ignore></div>

<script>
	import { init } from "@waline/client";
	import "@waline/client/style";

	init({
		el: "#waline",
		serverURL: "https://comment.zkl2333.com",
		path: location.pathname,
		lang: "zh-CN",
		// 深色模式跟随站点主题：当 <html data-theme="dark"> 时启用（Waline 内置监听，无需手动）
		dark: "html[data-theme='dark']",
		locale: {
			placeholder: "随便聊点什么吧……（支持 Markdown）",
		},
	});
</script>
