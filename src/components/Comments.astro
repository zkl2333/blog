---
// Waline 评论区。后端在独立子域名 comment.zkl2333.com。
// 合规策略（个人备案禁止评论交互）：挂载前先探测后端，连不上
// （如关闭 Waline docker）就彻底移除评论区——不显示空框、报错或
// 任何残留，与“没有评论功能”完全一致。一关 docker 即自动隐身。
---

<div id="waline" class="mt-12" data-pagefind-ignore hidden></div>

<script>
	import { init } from "@waline/client";
	import "@waline/client/style";

	const serverURL = "https://comment.zkl2333.com";
	const el = document.querySelector<HTMLElement>("#waline");

	void (async () => {
		if (!el) return;
		try {
			// 探测后端：带超时请求评论接口，确认在线且正常响应
			const ctrl = new AbortController();
			const timer = setTimeout(() => ctrl.abort(), 4000);
			const res = await fetch(
				`${serverURL}/api/comment?path=${encodeURIComponent(location.pathname)}&pageSize=1&page=1`,
				{ signal: ctrl.signal, headers: { Accept: "application/json" } },
			);
			clearTimeout(timer);
			if (!res.ok) throw new Error(`HTTP ${res.status}`);
			const data = await res.json();
			if (data && typeof data.errno !== "undefined" && data.errno !== 0) {
				throw new Error(`Waline errno ${data.errno}`);
			}

			// 后端在线 → 显示并挂载评论
			el.hidden = false;
			init({
				el,
				serverURL,
				path: location.pathname,
				lang: "zh-CN",
				// 深色模式跟随站点主题（Waline 内置监听）
				dark: "html[data-theme='dark']",
				locale: {
					placeholder: "随便聊点什么吧……（支持 Markdown）",
				},
			});
		} catch {
			// 后端连不上（如已关闭 Waline docker）→ 彻底移除，页面如同无评论功能
			el.remove();
		}
	})();
</script>

<style is:global>
	/* 让 Waline 评论区融入博客「小饭桌」暖色系统，并自动跟随明暗主题：
	   把 Waline 的颜色变量映射到博客现成的 theme-aware 变量即可，
	   light/dark 由 --color-* 自身切换，无需为 Waline 单独写暗色。 */
	#waline {
		/* 主色 → 焦糖橙 accent */
		--waline-theme-color: var(--color-accent);
		--waline-active-color: color-mix(in oklch, var(--color-accent) 85%, var(--color-accent-2));
		/* 文字 / 背景：融入页面、随明暗切换 */
		--waline-color: var(--color-global-text);
		--waline-bg-color: transparent;
		--waline-bg-color-light: var(--color-surface);
		--waline-bg-color-hover: color-mix(in oklch, var(--color-accent) 8%, transparent);
		--waline-border-color: var(--color-border);
		--waline-border: 1px solid var(--color-border);
		/* 引用块 / 禁用态 / 底部信息栏 */
		--waline-bq-color: color-mix(in oklch, var(--color-accent) 6%, var(--color-surface));
		--waline-disable-bg-color: var(--color-surface);
		--waline-disable-color: var(--color-muted);
		--waline-info-bg-color: color-mix(in oklch, var(--color-surface) 70%, transparent);
		--waline-info-color: var(--color-muted);
		/* 徽章用强调色，替掉默认的蓝 */
		--waline-badge-color: var(--color-accent);
		/* 字体跟随博客（霞鹜文楷） */
		font-family: var(--font-family-sans);
	}

	/* 输入框聚焦：暖色描边 + 柔光环，呼应博客交互风格 */
	#waline .wl-editor:focus,
	#waline .wl-input:focus {
		border-color: color-mix(in oklch, var(--color-accent) 45%, var(--color-border));
		box-shadow: 0 0 0 3px color-mix(in oklch, var(--color-accent) 12%, transparent);
	}

	/* 主发送按钮：实心焦糖橙，对齐博客 .btn--primary */
	#waline .wl-btn.primary {
		color: var(--color-global-bg);
		background: var(--color-accent);
		border-color: var(--color-accent);
	}
	#waline .wl-btn.primary:hover {
		background: color-mix(in oklch, var(--color-accent) 88%, black);
		border-color: color-mix(in oklch, var(--color-accent) 88%, black);
	}
</style>
