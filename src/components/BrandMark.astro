---
interface Props {
	size?: number;
	class?: string;
}

const { size = 40, class: className = "" } = Astro.props;
---

<svg
	aria-hidden="true"
	class={`brand-mark ${className}`}
	fill="none"
	height={size}
	viewBox="0 0 64 64"
	width={size}
	xmlns="http://www.w3.org/2000/svg"
>
	<path
		class="brand-mark__steam brand-mark__steam--side"
		d="M24 16c2.6 2.8-2.6 5 0 7.8"
		stroke-linecap="round"
		stroke-width="2"
	></path>
	<path
		class="brand-mark__steam"
		d="M32 13c2.6 2.8-2.6 5 0 7.8"
		stroke-linecap="round"
		stroke-width="2"
	></path>
	<path
		class="brand-mark__steam brand-mark__steam--side"
		d="M40 16c2.6 2.8-2.6 5 0 7.8"
		stroke-linecap="round"
		stroke-width="2"
	></path>
	<path
		class="brand-mark__rice"
		d="M18 33c1.8-2.4 6.2-3.8 14-3.8s12.2 1.4 14 3.8c-1.8 2-6.2 3-14 3s-12.2-1-14-3z"
	></path>
	<ellipse class="brand-mark__rim" cx="32" cy="33" rx="14" ry="2.2"></ellipse>
	<path
		class="brand-mark__bowl"
		d="M14 34c0 8.5 7 15 16 16.5h4C43 49 50 42.5 50 34z"
	></path>
	<path class="brand-mark__bowl-line" d="M14 34h36" stroke-linecap="round" stroke-width="1.2"></path>
	<circle class="brand-mark__seed" cx="26" cy="32" r="0.9"></circle>
	<circle class="brand-mark__seed" cx="32" cy="31.5" r="0.9"></circle>
	<circle class="brand-mark__seed" cx="38" cy="32" r="0.9"></circle>
</svg>
