---
import { Icon } from "astro-icon/components";
import { siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<footer class="site-footer">
	<img
		alt=""
		aria-hidden="true"
		class="site-footer__deco"
		height={1024}
		loading="lazy"
		src="/illustrations/breakfast.png"
		width={1024}
	/>
	<div class="site-footer__grid">
		<div class="site-footer__brand">
			<p class="site-footer__title">{siteConfig.title}</p>
			<p class="site-footer__note">
				一张桌，摆几道菜。<br />
				谁路过都能坐，<br />
				扒两口就走也行。
			</p>
			<ul class="site-footer__socials" role="list">
				<li>
					<a
						class="site-footer__social"
						href="https://github.com/zkl2333"
						rel="noreferrer"
						target="_blank"
						aria-label="GitHub"
					>
						<Icon aria-hidden="true" name="mdi:github" />
					</a>
				</li>
				<li>
					<a class="site-footer__social" href="/rss.xml" aria-label="RSS 订阅">
						<Icon aria-hidden="true" name="mdi:rss" />
					</a>
				</li>
			</ul>
		</div>

		<nav class="site-footer__col" aria-label="栏目">
			<p class="site-footer__heading">栏目</p>
			<ul role="list">
				<li><a href="/posts/">文章</a></li>
				<li><a href="/notes/">碎念</a></li>
				<li><a href="/links/">友链</a></li>
			</ul>
		</nav>

		<nav class="site-footer__col" aria-label="关于">
			<p class="site-footer__heading">关于</p>
			<ul role="list">
				<li><a href="/about/">关于我</a></li>
				<li><a href="/tags/">全部标签</a></li>
				<li><a href="/rss.xml">RSS 订阅</a></li>
			</ul>
		</nav>

		<nav class="site-footer__col" aria-label="联系">
			<p class="site-footer__heading">联系</p>
			<ul role="list">
				<li>
					<a href="https://github.com/zkl2333" rel="noreferrer" target="_blank">GitHub</a>
				</li>
				<li>
					<a href="https://github.com/zkl2333/blog/issues" rel="noreferrer" target="_blank">
						Issues
					</a>
				</li>
				<li>
					<a href="/rss.xml">RSS</a>
				</li>
			</ul>
		</nav>
	</div>
	<div class="site-footer__bottom">
		<span>&copy; 2017 – {year} {siteConfig.author} · {siteConfig.tagline}</span>
		<a class="site-footer__beian" href="https://beian.miit.gov.cn/" rel="nofollow" target="_blank"
			>浙ICP备17004361号-1</a
		>
	</div>
</footer>
