---
import { Icon } from "astro-icon/components";
import BrandMark from "@/components/BrandMark.astro";
import { siteConfig } from "@/site.config";

const year = new Date().getFullYear();

// 域名注册：2015-11-01 17:46:51（北京时间）
const launchDate = new Date("2015-11-01T17:46:51+08:00");
const buildDate = new Date();
const runDays = Math.floor((buildDate.getTime() - launchDate.getTime()) / (1000 * 60 * 60 * 24));
---

<footer class="site-footer">
	<div class="site-footer__row">
		<a class="site-footer__brand" href="/" aria-label={siteConfig.title}>
			<BrandMark size={24} />
			<span>{siteConfig.title}</span>
		</a>
		<span class="site-footer__item" title="域名注册于 2015-11-01">
			已运行 {runDays.toLocaleString()} 天
		</span>
		<span class="site-footer__item">
			&copy; 2015 – {year} {siteConfig.author}
		</span>
		<a class="site-footer__item site-footer__link" href="https://beian.miit.gov.cn/" rel="nofollow" target="_blank">
			浙ICP备17004361号-1
		</a>
		<a class="site-footer__item site-footer__link" href="/rss.xml" aria-label="RSS 订阅">
			<Icon aria-hidden="true" name="mdi:rss" />
			<span>RSS</span>
		</a>
		<a class="site-footer__item site-footer__link" href="https://github.com/zkl2333" rel="noreferrer" target="_blank" aria-label="GitHub">
			<Icon aria-hidden="true" name="mdi:github" />
			<span>GitHub</span>
		</a>
	</div>
</footer>
