---
import { Icon } from "astro-icon/components";
import { siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="site-footer__grid">
		<div class="site-footer__brand">
			<p class="site-footer__title">{siteConfig.title}</p>
			{siteConfig.tagline && <p class="site-footer__tagline">{siteConfig.tagline}</p>}
		</div>
		<nav class="site-footer__col" aria-label="栏目">
			<p class="site-footer__heading">栏目</p>
			<ul role="list">
				<li><a href="/posts/">文章</a></li>
				<li><a href="/notes/">碎念</a></li>
				<li><a href="/tags/">标签</a></li>
				<li><a href="/links/">友链</a></li>
			</ul>
		</nav>
		<nav class="site-footer__col" aria-label="关于">
			<p class="site-footer__heading">关于</p>
			<ul role="list">
				<li><a href="/about/">关于我</a></li>
				<li><a href="/rss.xml">RSS</a></li>
			</ul>
		</nav>
		<nav class="site-footer__col" aria-label="联系">
			<p class="site-footer__heading">联系</p>
			<ul role="list">
				<li>
					<a href="https://github.com/zkl2333" rel="noreferrer" target="_blank">
						<Icon aria-hidden="true" class="site-footer__icon" name="mdi:github" /> GitHub
					</a>
				</li>
			</ul>
		</nav>
	</div>
	<div class="site-footer__bottom">
		<span>&copy; 2017 – {year} {siteConfig.author} · {siteConfig.title}</span>
		<a class="site-footer__beian" href="https://beian.miit.gov.cn/" rel="nofollow" target="_blank"
			>浙ICP备17004361号-1</a
		>
	</div>
</footer>
