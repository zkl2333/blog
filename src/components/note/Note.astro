---
import { type CollectionEntry, render } from "astro:content";
import type { HTMLTag, Polymorphic } from "astro/types";
import FormattedDate from "@/components/FormattedDate.astro";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
	note: CollectionEntry<"note">;
	isPreview?: boolean | undefined;
	compact?: boolean | undefined;
};

const { as: Tag = "div", note, isPreview = false, compact = false } = Astro.props;
const { Content } = await render(note);
---

{
	compact ? (
		<a class="note-chip group" href={`/notes/${note.id}/`}>
			<span class="note-chip__dot" aria-hidden="true">·</span>
			<span class="note-chip__title">{note.data.title}</span>
			<FormattedDate class="note-chip__date" date={note.data.publishDate} />
		</a>
	) : (
		<article class="w-full" data-pagefind-body={isPreview ? false : true}>
			<Tag class="title block" class:list={{ "text-base": isPreview }}>
				{
					isPreview ? (
						<a class="cactus-link" href={`/notes/${note.id}/`}>
							{note.data.title}
						</a>
					) : (
						<>{note.data.title}</>
					)
				}
			</Tag>
			<FormattedDate class="text-muted font-semibold" date={note.data.publishDate} />
			{
				isPreview ? (
					<div class="prose prose-sm prose-cactus mt-1 line-clamp-2 max-w-none text-muted [&>p:last-of-type]:mb-0">
						<Content />
					</div>
				) : (
					<div class="prose prose-sm prose-cactus mt-4 max-w-none [&>p:last-of-type]:mb-0">
						<Content />
					</div>
				)
			}
		</article>
	)
}
